# 说明：
# 本文件为 macOS 平台基础配置骨架。
# 如需完整的 macOS 工程，请在 example/ 目录下执行：
#   flutter create --platforms=macos .
#
# 该命令会自动生成完整的 Xcode 工程、Runner 配置、
# Assets.xcassets 及 MainMenu 等。

platform :osx, '10.15'

# CocoaPods analytics sends network sync behavior
# and a spec repo update on `pod install`.
# opt_in by default, but you can opt-out with the following line.
# install! 'cocoapods', :disable_input_output_paths => true

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)
  end
end
